<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme using Android Material -->
    <style name="Theme.VF3Smart" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:colorPrimary">@color/vf3_blue</item>
        <item name="android:colorPrimaryDark">@color/vf3_dark_blue</item>
        <item name="android:colorAccent">@color/vf3_accent</item>
        <!-- statusBarColor / navigationBarColor were deprecated in API 35 and have
             no effect under edge-to-edge (enableEdgeToEdge() in MainActivity). The
             system bars draw transparent; content draws behind them. -->
    </style>
</resources>
