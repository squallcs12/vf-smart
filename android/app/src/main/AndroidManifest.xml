<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Launcher: start on boot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- AutoLink foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Required on Android 13+ to show foreground service notification -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Wake screen to allow AutoLink accessibility interaction -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Dim/restore screen brightness when Android Auto connects/disconnects -->
    <uses-permission android:name="android.permission.WRITE_SETTINGS" tools:ignore="ProtectedPermissions" />

    <!-- Network permissions for API and WebSocket -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- UDP discovery + WiFi scanning permissions -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />

    <!-- Location for nearby charging station lookup -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- BLE GATT server for navigation data (API < 31) -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <!-- BLE GATT server for navigation data (API 31+) -->
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- BLE hardware — not required so app runs on non-BLE devices -->
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="false" />

    <!-- Android Auto feature (optional) -->
    <uses-feature
        android:name="android.hardware.type.automotive"
        android:required="false" />

    <application
        android:name=".VF3Application"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.VF3Smart"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="31">

        <!-- Main Activity — also acts as the home screen launcher -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.VF3Smart"
            android:launchMode="singleTask"
            android:screenOrientation="landscape">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- AutoLink Pro monitor service -->
        <service
            android:name=".autolink.AutoLinkService"
            android:exported="false" />

        <!-- AutoLink Pro UI automation (requires user to enable in Settings > Accessibility) -->
        <service
            android:name=".autolink.AutoLinkAccessibilityService"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/autolink_accessibility_config" />
        </service>

        <!-- Boot receiver: relaunch after device restart -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Voice Assistant Activity (handles Google Assistant commands) -->
        <activity
            android:name=".ui.VoiceAssistantActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:launchMode="singleTask"
            android:excludeFromRecents="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="vf3smart"
                    android:host="command" />
            </intent-filter>
        </activity>

        <!-- Google Maps navigation notification listener -->
        <service
            android:name=".navigation.NavigationNotificationService"
            android:exported="true"
            android:label="Navigation Listener"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Android Auto Car App Service -->
        <service
            android:name=".auto.VF3AutoService"
            android:exported="true"
            android:label="@string/app_name"
            android:icon="@drawable/ic_launcher_auto">
            <intent-filter>
                <action android:name="androidx.car.app.CarAppService" />
                <category android:name="androidx.car.app.category.IOT" />
            </intent-filter>
        </service>

        <!-- Android Auto metadata -->
        <!-- IOT requires at least API level 2 -->
        <meta-data
            android:name="androidx.car.app.minCarApiLevel"
            android:value="2" />

        <meta-data
            android:name="com.google.android.gms.car.application"
            android:resource="@xml/automotive_app_desc" />

        <meta-data
            android:name="com.google.android.gms.car.distractionOptimized"
            android:value="true" />

        <!-- Google App Actions metadata -->
        <meta-data
            android:name="com.google.android.actions"
            android:resource="@xml/actions" />

        <!-- Google Assistant entity sets -->
        <meta-data
            android:name="com.google.android.actions.APP_ACTION_CAPABILITY"
            android:resource="@xml/entities" />
    </application>

</manifest>
